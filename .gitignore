# Root .gitignore for both backend and frontend

# Backend (Laravel)
backend/.env
backend/.env.backup
backend/.env.production
backend/node_modules
backend/vendor
backend/storage/*.key
backend/storage/app/public/events/*
backend/public/storage
backend/storage/debugbar/*.json
backend/storage/logs/*.log
backend/storage/framework/cache/data/*
backend/storage/framework/sessions/*
backend/storage/framework/testing/*
backend/storage/framework/views/*

# Frontend (React/Vite)
frontend/node_modules
frontend/dist
frontend/dist-ssr
frontend/*.local
frontend/*.log
frontend/npm-debug.log*

# OS Files
.DS_Store
Thumbs.db
*.log
.vscode/
.idea/
